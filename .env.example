# ─────────────────────────────────────────────────────────────────────────────
# PayChain AI — Environment Variables
# Copy this file to .env.local and fill in values before Phase 2 deployment.
# All variables must be prefixed with VITE_ to be exposed to the browser.
# ─────────────────────────────────────────────────────────────────────────────

# ── WalletConnect (Phase 2) ───────────────────────────────────────────────────
# Get your projectId from https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=YOUR_WALLETCONNECT_PROJECT_ID

# ── RPC Endpoints (Alchemy / Infura) ─────────────────────────────────────────
VITE_RPC_MAINNET=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
VITE_RPC_SEPOLIA=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
VITE_RPC_POLYGON=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
VITE_RPC_MUMBAI=https://polygon-mumbai.g.alchemy.com/v2/YOUR_KEY

# ── Backend API ───────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:4000/api/v1

# ── Gemini AI (Phase 2) ───────────────────────────────────────────────────────
# ⚠️  Never expose your Gemini key directly in frontend code.
#    Route all Gemini calls through your backend API.
VITE_GEMINI_API_URL=https://generativelanguage.googleapis.com/v1beta

# ── Feature Flags ─────────────────────────────────────────────────────────────
VITE_ENABLE_AI_FEATURES=false
VITE_ENABLE_MAINNET=false
