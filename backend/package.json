{
  "name": "paychain-ai-backend",
  "version": "2.0.0",
  "description": "PayChain AI — Phase 2 Backend: Express + MongoDB + Pinecone + Gemini 3",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start":     "node src/server.js",
    "dev":       "node --watch src/server.js",
    "dev:legacy": "nodemon src/server.js",
    "lint":      "eslint src/**/*.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@google/generative-ai":  "^0.3.0",
    "@pinecone-database/pinecone": "^2.2.0",
    "compression":            "^1.7.4",
    "cors":                   "^2.8.5",
    "dotenv":                 "^16.4.5",
    "express":                "^4.18.3",
    "express-rate-limit":     "^7.2.0",
    "express-validator":      "^7.0.1",
    "helmet":                 "^7.1.0",
    "mongoose":               "^8.2.2",
    "morgan":                 "^1.10.0",
    "uuid":                   "^9.0.1",
    "winston":                "^3.12.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "eslint":    "^8.57.0",
    "nodemon":   "^3.1.0"
  },
  "keywords": ["paychain", "web3", "ai", "merchant", "payments", "blockchain"]
}
