# ─────────────────────────────────────────────────────────────────────────────
# PayChain AI — Backend Environment Variables (Phase 2)
# ─────────────────────────────────────────────────────────────────────────────
# HOW TO USE:
#   cp backend/sample.env backend/.env
#   Fill in every required value, then: npm run dev
#
# REQUIRED keys are marked ★ — the server will REFUSE TO START without them.
# OPTIONAL keys fall back to sensible defaults for local development.
# ─────────────────────────────────────────────────────────────────────────────

# ── Runtime ───────────────────────────────────────────────────────────────────
NODE_ENV=development          # development | production | test
PORT=4000                     # must match VITE_API_BASE_URL in frontend .env

# ── MongoDB ★ ─────────────────────────────────────────────────────────────────
# Local:   mongodb://localhost:27017
# Atlas:   mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net
MONGODB_URI=mongodb://localhost:27017
DB_NAME=paychain_ai

# ── Pinecone ★ ────────────────────────────────────────────────────────────────
# Get your API key from: https://app.pinecone.io → API Keys
# Free Starter plan supports 1 serverless index — sufficient for Phase 2
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=paychain-transactions
PINECONE_DIMENSION=768        # Must match the embedding model output size
                              # text-embedding-004 → 768  (Phase 3)

# ── Gemini AI ★ ───────────────────────────────────────────────────────────────
# Get your key from: https://aistudio.google.com/app/apikey
# Phase 2 model: gemini-1.5-flash  (fast + cheap for status reports)
# Phase 3 model: gemini-1.5-pro    (more reasoning power for risk analysis)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# ── Security ──────────────────────────────────────────────────────────────────
# Phase 3: Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_USE_A_LONG_RANDOM_STRING_IN_PRODUCTION
JWT_EXPIRES_IN=7d

# Header name used by requireApiKey middleware (internal service-to-service calls)
API_KEY_HEADER=x-api-key
# Leave blank in development — set a strong random value in production
INTERNAL_API_KEY=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Production example: https://app.paychain.io,https://merchant.paychain.io
CORS_ORIGINS=http://localhost:5173

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000   # 15 minutes in milliseconds
RATE_LIMIT_MAX=100            # max requests per window per IP (global)
AI_RATE_LIMIT_MAX=20          # max AI requests per minute (Gemini endpoints)

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=debug               # error | warn | info | http | debug
LOG_DIR=logs                  # relative to backend/ root
